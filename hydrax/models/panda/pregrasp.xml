<!-- 7-DoF torque-controlled Panda for the pregrasp reach task.
     Generated from panda.xml (MjSpec): fingers/tendon/coupling and the
     position actuators removed, direct torque motors at the Franka
     limits added, contacts disabled, timestep = 25 Hz control period.
     Hand and finger bodies keep their inertia (fingers frozen). -->
<mujoco model="panda pregrasp">
  <compiler angle="radian" meshdir="assets/"/>

  <option timestep="0.04" integrator="implicitfast">
    <flag contact="disable"/>
  </option>

  <size nkey="1"/>

  <default>
    <default class="panda">
      <material shininess="0.25"/>
      <joint range="-2.8973 2.8973" armature="0.1" damping="1"/>
      <general ctrlrange="-2.8973 2.8973" forcerange="-100 100" biastype="affine" biasprm="0 -1"/>
      <default class="finger">
        <joint type="slide" range="0 0.04"/>
      </default>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom type="mesh" contype="0" conaffinity="0" group="3"/>
        <default class="primitive_collision">
          <geom type="box" solref="0.01" solimp="0.99 0.995 0.01"/>
          <default class="fingertip_pad_collision_1">
            <geom size="0.011 0.0075 0.01"/>
          </default>
          <default class="fingertip_pad_collision_2">
            <geom size="0.011 0.0044 0.0019"/>
